{
  "expo": {
    "name": "gracias-supercell",
    "slug": "gracias-supercell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon/web-app-manifest-512x512.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/favicon/web-app-manifest-512x512.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/favicon/web-app-manifest-512x512.png"
      },
      "package": "com.anonymous.graciassupercell"
    },
    "web": {
      "bundler": "metro",
      "staticPath": "web",
      "favicon": "./assets/favicon/favicon-96x96.png"
    }
  }
}
